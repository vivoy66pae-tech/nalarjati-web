# Server
PORT=3030
NODE_ENV=production

# Admin dashboard (basic auth) — CHANGE THESE!
ADMIN_USER=admin
ADMIN_PASS=changeme-please

# Public site URL
SITE_URL=https://nalarjati.dev

# Email / SMTP — leave blank to disable (submissions will be saved but not emailed)
# Mailgun example:
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@mg.nalarjati.dev
# SMTP_PASS=your-mailgun-smtp-password
# MAIL_FROM="nalarjati.dev <hello@nalarjati.dev>"
# MAIL_TO=hello@nalarjati.dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="nalarjati.dev <hello@nalarjati.dev>"
MAIL_TO=hello@nalarjati.dev

# Analytics — set to "1" to track pageviews (privacy-friendly, no cookies)
ANALYTICS_ENABLED=1
